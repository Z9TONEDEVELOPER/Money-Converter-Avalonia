<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:Money_Converter"
        mc:Ignorable="d" 
        x:Class="Money_Converter.MainWindow"
        x:DataType="local:MainWindow"
        Width="540" 
        Height="840"
        WindowStartupLocation="CenterScreen"
        Title="Конвертер валют"
        Icon="Assets/Icons/change.png">
        <Window.Background>
                <ImageBrush Source="Assets/Icons/background.png"
                            Stretch="UniformToFill"
                            Opacity="0.3"/>
        </Window.Background>
        <Grid>
            <Border Grid.Row="0" Grid.Column="0"
                    Background="#1E293B"  
                    CornerRadius="24"
                    BoxShadow="0 20 40 0 #00000060"  
                    Width="600" Height="550"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32">
            <ScrollViewer VerticalScrollBarVisibility="Auto"> 
                    <StackPanel Spacing="24">
                            <TextBlock Text="Конвертер валют"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>
                            <StackPanel>
                                    <TextBlock Text="Исходная валюта"
                                               FontSize="16"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,8"/>

                                    <Border Background="#334155" CornerRadius="12" Padding="12">
                                            <ComboBox ItemsSource="{Binding Currencies}"
                                                      SelectedItem="{Binding FromCurrency}"
                                                      PlaceholderText="Выберите валюту"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Foreground="White"/>
                                    </Border>
                            </StackPanel>
                            <Button Content="↔"
                                    Width="60" Height="60"
                                    FontSize="32"
                                    HorizontalAlignment="Center"
                                    Background="#6366F1"  
                                    CornerRadius="30"
                                    Margin="0,-20,0,-20"
                                    Click="RevertButton_Click"/>

                            <!-- Блок "Целевая валюта" -->
                            <StackPanel>
                                    <TextBlock Text="Целевая валюта"
                                               FontSize="16"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,8"/>

                                    <Border Background="#334155" CornerRadius="12" Padding="12">
                                            <ComboBox ItemsSource="{Binding Currencies}"
                                                      SelectedItem="{Binding ToCurrency}"
                                                      PlaceholderText="Выберите валюту"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Foreground="White"/>
                                    </Border>
                            </StackPanel>
                            <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Сумма"
                                   FontSize="16"
                                   Foreground="#94A3B8"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Введите сумму"
                                 FontSize="24"
                                 Padding="16"
                                 Background="#334155"
                                 BorderThickness="0"
                                 Foreground="White"
                                 CornerRadius="12"/>
                    </StackPanel>

                    <!-- Кнопка Конвертировать -->
                    <Button Content="Конвертировать"
                            FontSize="20" FontWeight="SemiBold"
                            Background="#F97316"  
                            Foreground="White"
                            CornerRadius="16"
                            Padding="24,16"
                            Margin="0,32,0,0"
                            HorizontalAlignment="Stretch"
                            Click="ConvertButton_Click"/>

                    <!-- Результат -->
                    <StackPanel Margin="0,32,0,0">
                        <TextBlock Text="Результат:"
                                   FontSize="18"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding Result}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>    
        </Border>

        <!-- Текст статуса загрузки (внизу или сверху карточки) -->
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="14"
                   Foreground="#60A5FA"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,32"/>
        </Grid>        
</Window>
